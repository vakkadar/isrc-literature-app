# HP home server deployment
# Copy to .env.hp on HP at /opt/isrc-literature-app/.env.hp
# DO NOT COMMIT real secrets

DJANGO_ENV=production
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_50_CHARS
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=isrc-literature.sanatanadharma.cloud,api.isrc-literature.sanatanadharma.cloud,localhost,127.0.0.1
WAGTAILADMIN_BASE_URL=https://api.isrc-literature.sanatanadharma.cloud
CORS_ALLOWED_ORIGINS=https://isrc-literature.sanatanadharma.cloud
CSRF_TRUSTED_ORIGINS=https://isrc-literature.sanatanadharma.cloud,https://api.isrc-literature.sanatanadharma.cloud

# Cloudflare Tunnel terminates TLS — do not double-redirect
SECURE_SSL_REDIRECT=False

# Postgres in shared isrc-modern-db-1 container (pgvector pg16) on isrc-modern_default network
POSTGRES_DB=isrc_literature
POSTGRES_USER=isrc_literature_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=isrc-modern-db-1
POSTGRES_PORT=5432

# Email (Gmail SMTP — use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=rajkumar.vakkada@gmail.com
EMAIL_HOST_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=ISRC Literature <rajkumar.vakkada@gmail.com>
CRAWLER_DIGEST_EMAIL=rajkumar.vakkada@gmail.com

# Crawler keys (add when ready)
YOUTUBE_API_KEY=
LISTEN_NOTES_API_KEY=

# Superuser seed (used by seed_superuser command)
DJANGO_SUPERUSER_USERNAME=rvakkada
DJANGO_SUPERUSER_EMAIL=rajkumar.vakkada@gmail.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
